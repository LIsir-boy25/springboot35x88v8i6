<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yb.dao.QuyuDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.yb.entity.QuyuEntity" id="quyuMap">
        <result property="quyu" column="quyu"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.yb.entity.vo.QuyuVO" >
		SELECT * FROM quyu  quyu         
        <where>${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.yb.entity.vo.QuyuVO" >
		SELECT  quyu.* FROM quyu  quyu 	
 		<where>${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.yb.entity.view.QuyuView" >

		SELECT  quyu.* FROM quyu  quyu 	        
        <where>${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.yb.entity.view.QuyuView" >
		SELECT * FROM quyu  quyu <where>${ew.sqlSegment}</where>
	</select>
	


</mapper>
