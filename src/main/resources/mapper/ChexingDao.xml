<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yb.dao.ChexingDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.yb.entity.ChexingEntity" id="chexingMap">
        <result property="chexing" column="chexing"/>
        <result property="jiage" column="jiage"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.yb.entity.vo.ChexingVO" >
		SELECT * FROM chexing  chexing         
        <where>${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.yb.entity.vo.ChexingVO" >
		SELECT  chexing.* FROM chexing  chexing 	
 		<where>${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.yb.entity.view.ChexingView" >

		SELECT  chexing.* FROM chexing  chexing 	        
        <where>${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.yb.entity.view.ChexingView" >
		SELECT * FROM chexing  chexing <where>${ew.sqlSegment}</where>
	</select>
	


</mapper>
