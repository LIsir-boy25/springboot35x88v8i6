        <where>${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.yb.entity.view.HuozhuView" >
		SELECT * FROM huozhu  huozhu <where>${ew.sqlSegment}</where>
	</select>
	


