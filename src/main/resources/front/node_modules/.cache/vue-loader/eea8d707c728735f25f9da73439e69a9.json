{"remainingRequest":"C:\\Users\\86173\\Desktop\\XM\\springboot35x88v8i6\\src\\main\\resources\\front\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!C:\\Users\\86173\\Desktop\\XM\\springboot35x88v8i6\\src\\main\\resources\\front\\src\\components\\tmap.vue?vue&type=style&index=0&id=16243478&lang=css","dependencies":[{"path":"C:\\Users\\86173\\Desktop\\XM\\springboot35x88v8i6\\src\\main\\resources\\front\\src\\components\\tmap.vue","mtime":1777116546179},{"path":"C:\\Users\\86173\\Desktop\\XM\\springboot35x88v8i6\\src\\main\\resources\\front\\node_modules\\css-loader\\dist\\cjs.js","mtime":1777233528103},{"path":"C:\\Users\\86173\\Desktop\\XM\\springboot35x88v8i6\\src\\main\\resources\\front\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1777233530577},{"path":"C:\\Users\\86173\\Desktop\\XM\\springboot35x88v8i6\\src\\main\\resources\\front\\node_modules\\postcss-loader\\src\\index.js","mtime":1777233528988},{"path":"C:\\Users\\86173\\Desktop\\XM\\springboot35x88v8i6\\src\\main\\resources\\front\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1777233527167},{"path":"C:\\Users\\86173\\Desktop\\XM\\springboot35x88v8i6\\src\\main\\resources\\front\\node_modules\\vue-loader\\lib\\index.js","mtime":1777233529725}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:CgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoubWFwQ29tcG9uZW50c3sKCXdpZHRoOiAxMDAlOwoJaGVpZ2h0OiA1MDBweDsKfQo="},{"version":3,"sources":["tmap.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AA+FA;AACA;AACA;AACA","file":"tmap.vue","sourceRoot":"src/components","sourcesContent":["<template>\n\t<div class=\"mapComponents\" id=\"container\"></div>\n</template>\n\n<script>\n\timport AMapLoader from \"@amap/amap-jsapi-loader\";\n\texport default {\n\t\tdata() {\n\t\t\treturn {\n\t\t\t\tmap: null,\n\t\t\t}\n\t\t},\n\t\tmounted() {\n\t\t\t// this.initAMap();\n\t\t},\n\t\tprops: ['longitude1','longitude2','latitude1','latitude2'],\n\t\tmethods: {\n\t\t\tmapClose(){\n\t\t\t\tthis.map.destroy();\n\t\t\t},\n\t\t\tasync initAMap(longitude1,longitude2,latitude1,latitude2, waypoints = []) {\n\t\t\t\tawait this.$http.get('config/info?name=gaode').then(rs=>{\r\n\t\t\t\t\tif(rs.data.data&&rs.data.data.value) {\r\n\t\t\t\t\t\tlet res = JSON.parse(rs.data.data.value)\r\n\t\t\t\t\t\tif(window._AMapSecurityConfig==undefined) {\r\n\t\t\t\t\t\t\twindow._AMapSecurityConfig = {\r\n\t\t\t\t\t\t\t\tsecurityJsCode: res.code,\r\n\t\t\t\t\t\t\t};\r\n\t\t\t\t\t\t}\r\n\t\t\t\t\t\tthis.$nextTick(()=>{\r\n\t\t\t\t\t\t\tthis.initAfate(res.key,longitude1,longitude2,latitude1,latitude2, waypoints)\r\n\t\t\t\t\t\t})\r\n\t\t\t\t\t}\r\n\t\t\t\t})\n\t\t\t},\r\n\t\t\tinitAfate(key,longitude1,longitude2,latitude1,latitude2, waypoints = []){\n\t\t\t\tlet that = this\n\t\t\t\tAMapLoader.reset()\n\t\t\t\tAMapLoader.load({\n\t\t\t\t\t\tkey: key, // 申请好的Web端开发者Key，首次调用 load 时必填\n\t\t\t\t\t\tversion: \"2.0\", // 指定要加载的 JSAPI 的版本，缺省时默认为 1.4.15\n\t\t\t\t\t\t// plugins: ['AMap.Driving'], // 需要使用的的插件列表，如比例尺'AMap.Scale'等\n\t\t\t\t\t})\n\t\t\t\t\t.then((AMap) => {\n\t\t\t\t\t\tthis.map = new AMap.Map(\"container\", {\n\t\t\t\t\t\t\t// 设置地图容器id\n\t\t\t\t\t\t\t// viewMode: \"3D\", // 是否为3D地图模式\n\t\t\t\t\t\t\tzoom: 14, // 初始化地图级别\n\t\t\t\t\t\t\tcenter: [longitude1, latitude1], //地图显示中心点坐标\n\t\t\t\t\t\t});\n\t\t\t\t\t\tif(longitude1&&longitude2&&latitude1&&latitude2){\r\n\t\t\t\t\t\t\tlet arr = []\r\n\t\t\t\t\t\t\tif (waypoints.length) {\r\n\t\t\t\t\t\t\t\tfor(let x in waypoints) {\r\n\t\t\t\t\t\t\t\t\tarr.push(new AMap.LngLat(waypoints[x].split(',')[1], waypoints[x].split(',')[0]))\r\n\t\t\t\t\t\t\t\t}\r\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tAMap.plugin('AMap.Driving',\n\t\t\t\t\t\t\t\tfunction() {\n\t\t\t\t\t\t\t\t\tvar driving = new AMap.Driving({\n\t\t\t\t\t\t\t\t\t\tmap: that.map,\n\t\t\t\t\t\t\t\t\t}); //驾车路线规划\n\t\t\t\t\t\t\t\t\tdriving.search(\n\t\t\t\t\t\t\t\t\t\tnew AMap.LngLat(longitude1, latitude1),\n\t\t\t\t\t\t\t\t\t\tnew AMap.LngLat(longitude2, latitude2),\r\n\t\t\t\t\t\t\t\t\t\t{\r\n\t\t\t\t\t\t\t\t\t\t\twaypoints: arr\r\n\t\t\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\t\t\tfunction(status, result) {\n\t\t\t\t\t\t\t\t\t\t\tconsole.log(status)\n\t\t\t\t\t\t\t\t\t\t\t// result 即是对应的驾车导航信息，相关数据结构文档请参考  https://lbs.amap.com/api/javascript-api/reference/route-search#m_DrivingResult\n\t\t\t\t\t\t\t\t\t\t\tif (status === \"complete\") {\n\t\t\t\t\t\t\t\t\t\t\t\tconsole.log(\"绘制驾车路线完成\", result);\n\t\t\t\t\t\t\t\t\t\t\t} else {\n\t\t\t\t\t\t\t\t\t\t\t\tconsole.log(\"获取驾车数据失败：\" + result);\n\t\t\t\t\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t\t\t);\n\t\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t);\n\t\t\t\t\t\t}else {\r\n\t\t\t\t\t\t\tthis.$message.error('起终点经纬度不完整')\r\n\t\t\t\t\t\t}\n\t\t\t\t\t})\n\t\t\t\t\t.catch((e) => {\n\t\t\t\t\t\tconsole.log(e);\n\t\t\t\t\t});\n\t\t\t\r\n\t\t\t\t\r\n\t\t\t},\n\t\t}\n\t}\n</script>\n\n<style>\n\t.mapComponents{\n\t\twidth: 100%;\n\t\theight: 500px;\n\t}\n</style>"]}]}