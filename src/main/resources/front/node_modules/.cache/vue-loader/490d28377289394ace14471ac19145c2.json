"sourcesContent":["<template>\r\n\t<div>\r\n\t\t<div class=\"breadcrumb-preview\">\r\n\t\t\t<el-breadcrumb :separator=\"'>>'\">\r\n\t\t\t\t<el-breadcrumb-item class=\"item1\" to=\"/\"><a>首页</a></el-breadcrumb-item>\r\n\t\t\t\t<el-breadcrumb-item class=\"item2\" v-for=\"(item, index) in breadcrumbItem\" :key=\"index\"><a>{{item.name}}</a></el-breadcrumb-item>\r\n\t\t\t</el-breadcrumb>\r\n\t\t</div>\r\n\t\t<div v-if=\"centerType \" class=\"back_box\">\r\n\t\t\t<el-button class=\"backBtn\" size=\"mini\" @click=\"backClick\">\r\n\t\t\t\t<span class=\"icon iconfont icon-fanhui12\"></span>\r\n\t\t\t\t<span class=\"text\">返回</span>\r\n\t\t\t</el-button>\r\n\t\t</div>\r\n\t\t<div class=\"list-preview\">\r\n\t\t\t<el-form :inline=\"true\" :model=\"formSearch\" class=\"list-form-pv\">\r\n\t\t\t\t<el-form-item class=\"list-item\" >\r\n\t\t\t\t\t<div class=\"lable\">订单编号：</div>\r\n\t\t\t\t\t<el-input v-model=\"formSearch.dingdanbianhao\" placeholder=\"订单编号\" @keydown.enter.native=\"getList(1, curFenlei)\" clearable></el-input>\r\n\t\t\t\t</el-form-item>\r\n\t\t\t\t<el-form-item class=\"list-item\" >\r\n\t\t\t\t\t<div class=\"lable\">货物类型：</div>\r\n\t\t\t\t\t<el-input v-model=\"formSearch.huowuleixing\" placeholder=\"货物类型\" @keydown.enter.native=\"getList(1, curFenlei)\" clearable></el-input>\r\n\t\t\t\t</el-form-item>\r\n\t\t\t\t<div class=\"list-btn-box\">\r\n\t\t\t\t\t<el-button class=\"list-search-btn\" v-if=\" true \" type=\"primary\" @click=\"getList(1, curFenlei)\">\r\n\t\t\t\t\t\t<span class=\"icon iconfont icon-fangdajing07\"></span>\r\n\t\t\t\t\t\t搜索\r\n\t\t\t\t\t</el-button>\r\n\t\t\t\t\t<el-button class=\"list-add-btn\" v-if=\"btnAuth('xiehuoxinxi','新增')\" type=\"primary\" @click=\"add('/index/xiehuoxinxiAdd')\">\r\n\t\t\t\t\t\t<span class=\"icon iconfont icon-tianjia7\"></span>\r\n\t\t\t\t\t\t新增\r\n\t\t\t\t\t</el-button>\r\n  \r\n\t\t\t\t</div>\r\n\t\t\t</el-form>\r\n\t\t\t<div class=\"select2\">\r\n\t\t\t\t<div class=\"select2-list\" v-for=\"(item,index) in selectOptionsList\" :key=\"index\">\r\n\t\t\t\t\t<div class=\"label\">{{item.name}}：</div>\r\n\t\t\t\t\t<div class=\"item-body\">\r\n\t\t\t\t\t\t<div class=\"item\" @click=\"selectClick2(item,-1)\" :class=\"item.check ==-1 ? 'active' : ''\">全部</div>\r\n\t\t\t\t\t\t<div class=\"item\" @click=\"selectClick2(item,index1)\" :class=\"item.check == index1 ? 'active' : ''\" v-for=\"item1,index1 in item.list\" :key=\"index1\">{{item1}}</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t\t<div class=\"list\">\r\n\t\t\t\t<div class=\"list5\">\r\n\t\t\t\t\t<div v-for=\"(item,index) in dataList\" :key=\"index\" class=\"list-item\" @click.stop=\"toDetail(item)\" >\r\n\t\t\t\t\t\t<div class=\"imgbox\">\r\n\t\t\t\t\t\t\t<img @click.stop=\"imgPreView(item.xiehuotupian)\" v-if=\"item.xiehuotupian && item.xiehuotupian.substr(0,4)=='http'&&item.xiehuotupian.split(',w').length>1\" :src=\"item.xiehuotupian\" class=\"image\" />\r\n\t\t\t\t\t\t\t<img @click.stop=\"imgPreView(item.xiehuotupian.split(',')[0])\" v-else-if=\"item.xiehuotupian && item.xiehuotupian.substr(0,4)=='http'\" :src=\"item.xiehuotupian.split(',')[0]\" class=\"image\" />\r\n\t\t\t\t\t\t\t<img @click.stop=\"imgPreView(baseUrl + (item.xiehuotupian?item.xiehuotupian.split(',')[0]:''))\" v-else :src=\"baseUrl + (item.xiehuotupian?item.xiehuotupian.split(',')[0]:'')\" class=\"image\" />\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div class=\"infoBox\">\r\n\t\t\t\t\t\t\t<div class=\"name\">{{item.dingdanbianhao}}</div>\r\n\t\t\t\t\t\t\t<div class=\"name\">{{item.quyu}}</div>\r\n\t\t\t\t\t\t\t<div class=\"name\">{{item.huowuleixing}}</div>\r\n\t\t\t\t\t\t\t<div class=\"name\">{{item.zhongliang}}</div>\r\n\t\t\t\t\t\t\t<div class=\"name\">{{item.tiji}}</div>\r\n\t\t\t\t\t\t\t<div class=\"name\">收货确认:{{item.shouhuoqueren}}</div>\r\n\t\t\t\t\t\t\t<div class=\"bottomInfo\">\r\n\t\t\t\t\t\t\t\t<div class=\"time_item\">\r\n\t\t\t\t\t\t\t\t\t<span class=\"icon iconfont icon-shijian21\"></span>\r\n\t\t\t\t\t\t\t\t\t<span class=\"label\">发布时间：</span>\r\n\t\t\t\t\t\t\t\t\t<span class=\"text\">{{item.addtime.split(' ')[0]}}</span>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t\t<div class=\"publisher_item\">\r\n\t\t\t\t\t\t\t\t\t<span class=\"icon iconfont icon-geren16\"></span>\r\n\t\t\t\t\t\t\t\t\t<span class=\"label\">发布人：</span>\r\n\t\t\t\t\t\t\t\t\t<span class=\"text\">{{item.sijizhanghao}}</span>\r\n\t\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\r\n\t\r\n\t\t\t<el-pagination\r\n\t\t\t\tbackground\r\n\t\t\t\tid=\"pagination\"\r\n\t\t\t\tclass=\"pagination\"\r\n\t\t\t\t:pager-count=\"7\"\r\n\t\t\t\t:page-size=\"pageSize\"\r\n\t\t\t\tprev-text=\"<\"\r\n\t\t\t\tnext-text=\">\"\r\n\t\t\t\t:hide-on-single-page=\"true\"\r\n\t\t\t\t:layout='[\"total\",\"prev\",\"pager\",\"next\",\"sizes\",\"jumper\"].join()'\r\n\t\t\t\t:total=\"total\"\r\n\t\t\t\t:page-sizes=\"pageSizes\"\r\n\t\t\t\t@current-change=\"curChange\"\r\n\t\t\t\t@size-change=\"sizeChange\"\r\n\t\t\t\t@prev-click=\"prevClick\"\r\n\t\t\t\t@next-click=\"nextClick\"\r\n\t\t\t\t></el-pagination>\r\n\t\t</div>\r\n\t\t<el-dialog title=\"预览图\" :visible.sync=\"previewVisible\" width=\"50%\">\r\n\t\t\t<img :src=\"previewImg\" alt=\"\" style=\"width: 100%;\">\r\n\t\t</el-dialog>\r\n\t</div>\r\n</template>\r\n<script>\r\n\timport axios from 'axios';\r\n\texport default {\r\n\t\t//数据集合\r\n\t\tdata() {\r\n\t\t\treturn {\r\n\t\t\t\tselectIndex2: 0,\r\n\t\t\t\tselectOptionsList: [],\r\n\t\t\t\tlayouts: '',\r\n\t\t\t\tswiperIndex: -1,\r\n\t\t\t\tbaseUrl: '',\r\n\t\t\t\tbreadcrumbItem: [\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tname: '卸货信息'\r\n\t\t\t\t\t}\r\n\t\t\t\t],\r\n\t\t\t\tformSearch: {\r\n\t\t\t\t\tdingdanbianhao: '',\r\n\t\t\t\t\thuowuleixing: '',\r\n\t\t\t\t\tshouhuoqueren: '',\r\n\t\t\t\t},\r\n\t\t\t\tfenlei: [],\r\n\t\t\t\tdataList: [],\r\n\t\t\t\ttotal: 1,\r\n\t\t\t\tpageSize: 12,\r\n\t\t\t\tpageSizes: [],\r\n\t\t\t\ttotalPage: 1,\r\n\t\t\t\tcurFenlei: '全部',\r\n\t\t\t\tisPlain