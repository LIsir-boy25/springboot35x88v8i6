upian:''\"\r\n\t\t\t\t\t@change=\"xiehuotupianUploadChange\"\r\n\t\t\t\t\t></file-upload>\r\n\t\t\t</el-form-item>\r\n\t\t\t<el-form-item class=\"add-item\" v-else label=\"卸货图片\" prop=\"xiehuotupian\">\r\n\t\t\t\t<img v-if=\"ruleForm.xiehuotupian.substring(0,4)=='http'\" class=\"upload-img\" v-bind:key=\"index\" :src=\"ruleForm.xiehuotupian.split(',')[0]\">\r\n\t\t\t\t<img v-else class=\"upload-img\" v-bind:key=\"index\" v-for=\"(item,index) in ruleForm.xiehuotupian.split(',')\" :src=\"baseUrl+item\">\r\n\t\t\t</el-form-item>\r\n\t\t\t<el-form-item class=\"add-item\"  label=\"星级评分\" prop=\"xingjipingfen\">\r\n\t\t\t\t<el-select v-model=\"ruleForm.xingjipingfen\" placeholder=\"请选择星级评分\" :disabled=\"ro.xingjipingfen\"  filterable>\r\n\t\t\t\t\t<el-option\r\n\t\t\t\t\t\tv-for=\"(item,index) in xingjipingfenOptions\"\r\n\t\t\t\t\t\t:key=\"index\"\r\n\t\t\t\t\t\t:label=\"item\"\r\n\t\t\t\t\t\t:value=\"item\">\r\n\t\t\t\t\t</el-option>\r\n\t\t\t\t</el-select>\r\n\t\t\t</el-form-item>\r\n\t\t\t<el-form-item class=\"add-item\" label=\"服务评价\" prop=\"fuwupingjia\">\r\n\t\t\t\t<el-input v-model=\"ruleForm.fuwupingjia\" \r\n\t\t\t\t\tplaceholder=\"服务评价\" clearable :readonly=\"ro.fuwupingjia\"></el-input>\r\n\t\t\t</el-form-item>\r\n\t\t\t<el-form-item class=\"add-item\" label=\"评价时间\" prop=\"pingjiashijian\">\r\n\t\t\t\t<el-date-picker\r\n\t\t\t\t\t:disabled=\"ro.pingjiashijian\"\r\n\t\t\t\t\tvalue-format=\"yyyy-MM-dd HH:mm:ss\"\r\n\t\t\t\t\tv-model=\"ruleForm.pingjiashijian\" \r\n\t\t\t\t\ttype=\"datetime\"\r\n\t\t\t\t\tplaceholder=\"评价时间\">\r\n\t\t\t\t</el-date-picker>\r\n\t\t\t</el-form-item>\r\n\t\t\t<el-form-item class=\"add-item\" label=\"货主账号\" prop=\"huozhuzhanghao\">\r\n\t\t\t\t<el-input v-model=\"ruleForm.huozhuzhanghao\" \r\n\t\t\t\t\tplaceholder=\"货主账号\" clearable :readonly=\"ro.huozhuzhanghao\"></el-input>\r\n\t\t\t</el-form-item>\r\n\t\t\t<el-form-item class=\"add-item\" label=\"货主姓名\" prop=\"huozhuxingming\">\r\n\t\t\t\t<el-input v-model=\"ruleForm.huozhuxingming